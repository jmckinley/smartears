# App Store Connect API credentials for one-command TestFlight uploads.
#
# 1. Copy this file:   cp Config/asc.env.example Config/asc.env
# 2. Fill in the two IDs below.
# 3. Put your downloaded AuthKey_<KEY_ID>.p8 here (created once, never re-downloadable):
#       mkdir -p ~/.appstoreconnect/private_keys
#       mv ~/Downloads/AuthKey_XXXXXXXXXX.p8 ~/.appstoreconnect/private_keys/
#
# Config/asc.env and *.p8 are gitignored — they never get committed.
#
# Then ship a build with:   scripts/testflight.sh release

# Key ID — shown next to the key in App Store Connect (e.g. 2X9ABC3DEF)
export ASC_KEY_ID="REPLACE_WITH_KEY_ID"

# Issuer ID — at the top of the Keys page (a UUID)
export ASC_ISSUER_ID="REPLACE_WITH_ISSUER_ID"

# Optional: only set if your .p8 is NOT in ~/.appstoreconnect/private_keys/
# export ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_${ASC_KEY_ID}.p8"
